{
    "extends": ["config:recommended", "group:allNonMajor", "schedule:weekends", ":automergePatch"],
    "rangeStrategy": "update-lockfile",
    "postUpdateOptions": ["npmDedupe"],
    "lockFileMaintenance": {
        "enabled": true
    },
    "composer": {
        "enabled": false
    },
    "internalChecksFilter": "strict",
    "minimumReleaseAge": "5 days",
    "packageRules": [
        {
            "matchUpdateTypes": ["lockFileMaintenance"],
            "minimumReleaseAge": null
        },
        {
            "matchPackageNames": ["pdfjs-dist"],
            "allowedVersions": "<=5.4.530"
        },
        {
            "matchPackageNames": ["jquery"],
            "allowedVersions": "<4"
        }
    ]
}
